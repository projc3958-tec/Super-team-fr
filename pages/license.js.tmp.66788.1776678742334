import { useState, useEffect } from 'react';
import { useRouter } from 'next/router';

const API = process.env.NEXT_PUBLIC_API_URL || 'http://localhost:3001';

export default function LicensePage() {
  const [licenseKey, setLicenseKey] = useState('');
  const [deviceId, setDeviceId] = useState('');
  const [status, setStatus] = useState('idle'); // idle | loading | success | error
  const [error, setError] = useState('');
  const router = useRouter();

  useEffect(() => {
    if (typeof window !== 'undefined' && window.electronAPI) {
      window.electronAPI.getDeviceId().then(setDeviceId);
    }
  }, []);

  const handleKeyInput = (e) => {
    // Auto-format as XXXXX-XXXXX-XXXXX-XXXXX while typing
    let val = e.target.value.toUpperCase().replace(/[^A-Z0-9]/g, '');
    const parts = val.match(/.{1,5}/g) || [];
    setLicenseKey(parts.join('-').substring(0, 23));
  };

  const activate = async () => {
    const trimmed = licenseKey.trim();
    if (!trimmed || trimmed.length < 23) return;
    if (!deviceId) return setError('Could not read device ID.');

    setStatus('loading');
    setError('');

    try {
      const res = await fetch(`${API}/api/license/activate`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ key: trimmed, deviceId }),
      });

      const data = await res.json();

      if (!res.ok) {
        setError(data.error || 'Invalid license key.');
        setStatus('error');
        return;
      }

      if (window.electronAPI) await window.electronAPI.saveLicense(trimmed);
      setStatus('success');
      setTimeout(() => router.replace('/'), 1200);
    } catch {
      setError('Could not reach the license server. Check your internet connection.');
      setStatus('error');
    }
  };

  const inputStyle = {
    width: '100%',
    padding: '14px 16px',
    fontSize: '18px',
    fontFamily: "'Courier New', monospace",
    letterSpacing: '3px',
    textAlign: 'center',
    color: '#f1f5f9',
    background: 'rgba(30, 41, 59, 0.6)',
    border: `1px solid ${status === 'error' ? '#ef4444' : 'rgba(255,255,255,0.12)'}`,
    borderRadius: '12px',
    outline: 'none',
    transition: 'all 0.2s',
  };

  return (
    <>
      <style jsx global>{`
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'DM Sans', -apple-system, sans-serif; background: #0a0f1c; }
      `}</style>

      <div style={{
        minHeight: '100vh',
        background: 'linear-gradient(135deg, #0a0f1c 0%, #111827 50%, #0f172a 100%)',
        display: 'flex',
        alignItems: 'center',
        justifyContent: 'center',
        padding: '40px 20px',
      }}>
        {/* Glow blobs */}
        <div style={{ position: 'fixed', top: '-20%', left: '-10%', width: '500px', height: '500px', background: 'radial-gradient(circle, rgba(34,211,238,0.07) 0%, transparent 70%)', borderRadius: '50%', pointerEvents: 'none' }} />
        <div style={{ position: 'fixed', bottom: '-20%', right: '-10%', width: '500px', height: '500px', background: 'radial-gradient(circle, rgba(16,185,129,0.05) 0%, transparent 70%)', borderRadius: '50%', pointerEvents: 'none' }} />

        <div style={{
          width: '100%',
          maxWidth: '480px',
          background: 'rgba(17,24,39,0.85)',
          backdropFilter: 'blur(20px)',
          borderRadius: '24px',
          border: '1px solid rgba(255,255,255,0.08)',
          boxShadow: '0 25px 80px rgba(0,0,0,0.5)',
          padding: '48px 40px',
          position: 'relative',
          zIndex: 1,
        }}>

          {/* Icon + Title */}
          <div style={{ textAlign: 'center', marginBottom: '36px' }}>
            <div style={{
              width: '56px', height: '56px', margin: '0 auto 16px',
              background: 'linear-gradient(135deg, #22d3ee, #10b981)',
              borderRadius: '16px', display: 'flex', alignItems: 'center', justifyContent: 'center',
              fontSize: '28px', boxShadow: '0 8px 32px rgba(34,211,238,0.25)',
            }}>🔑</div>
            <h1 style={{ fontSize: '26px', fontWeight: '700', color: '#f1f5f9', marginBottom: '8px' }}>
              Activate License
            </h1>
            <p style={{ fontSize: '14px', color: '#64748b', lineHeight: '1.6' }}>
              Enter your license key to unlock Resume Tailor on this device.
            </p>
          </div>

          {/* License key input */}
          <div style={{ marginBottom: '20px' }}>
            <label style={{ display: 'block', fontSize: '12px', fontWeight: '600', color: '#94a3b8', marginBottom: '8px', textTransform: 'uppercase', letterSpacing: '0.5px' }}>
              License Key
            </label>
            <input
              value={licenseKey}
              onChange={handleKeyInput}
              placeholder="XXXXX-XXXXX-XXXXX-XXXXX"
              maxLength={23}
              disabled={status === 'loading' || status === 'success'}
              style={inputStyle}
              onFocus={e => { e.target.style.borderColor = '#22d3ee'; e.target.style.boxShadow = '0 0 0 3px rgba(34,211,238,0.1)'; }}
              onBlur={e => { e.target.style.borderColor = status === 'error' ? '#ef4444' : 'rgba(255,255,255,0.12)'; e.target.style.boxShadow = 'none'; }}
              onKeyDown={e => e.key === 'Enter' && activate()}
            />
            {status === 'error' && (
              <p style={{ marginTop: '8px', fontSize: '13px', color: '#ef4444' }}>{error}</p>
            )}
          </div>

          {/* Activate button */}
          <button
            onClick={activate}
            disabled={licenseKey.length < 23 || status === 'loading' || status === 'success'}
            style={{
              width: '100%', padding: '16px', fontSize: '15px', fontWeight: '600',
              color: (licenseKey.length < 23 || status === 'loading' || status === 'success') ? '#64748b' : '#0a0f1c',
              background: status === 'success'
                ? 'linear-gradient(135deg, #10b981, #059669)'
                : (licenseKey.length < 23 || status === 'loading')
                  ? 'rgba(51,65,85,0.5)'
                  : 'linear-gradient(135deg, #22d3ee, #10b981)',
              border: 'none', borderRadius: '12px', cursor: licenseKey.length < 23 ? 'not-allowed' : 'pointer',
              transition: 'all 0.3s', display: 'flex', alignItems: 'center', justifyContent: 'center', gap: '8px',
              boxShadow: licenseKey.length >= 23 && status === 'idle' ? '0 8px 32px rgba(34,211,238,0.2)' : 'none',
            }}
          >
            {status === 'loading' && <span style={{ width: '18px', height: '18px', border: '2px solid transparent', borderTopColor: '#64748b', borderRadius: '50%', animation: 'spin 1s linear infinite', display: 'inline-block' }} />}
            {status === 'success' ? '✓ Activated — launching app...' : status === 'loading' ? 'Activating...' : 'Activate License'}
          </button>

          {/* Device ID */}
          {deviceId && (
            <div style={{ marginTop: '28px', padding: '14px 16px', background: 'rgba(30,41,59,0.4)', borderRadius: '10px', border: '1px solid rgba(255,255,255,0.05)' }}>
              <p style={{ fontSize: '11px', color: '#475569', marginBottom: '4px', textTransform: 'uppercase', letterSpacing: '0.5px' }}>Your Device ID</p>
              <p style={{ fontSize: '11px', fontFamily: 'monospace', color: '#64748b', wordBreak: 'break-all' }}>{deviceId}</p>
              <p style={{ fontSize: '11px', color: '#475569', marginTop: '6px' }}>Share this with your administrator to get a license key.</p>
            </div>
          )}
        </div>
      </div>

      <style jsx>{`
        @keyframes spin { to { transform: rotate(360deg); } }
      `}</style>
    </>
  );
}
